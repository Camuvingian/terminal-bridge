{
    "name": "terminal-bridge",
    "version": "1.6.0",
    "description": "Access a full web terminal and AI chat interface from anywhere. Built with xterm.js, tmux, and the Claude Agent SDK for macOS and Linux.",
    "type": "module",
    "license": "MIT",
    "keywords": [
        "terminal",
        "web-terminal",
        "xterm",
        "tmux",
        "ai-chat",
        "claude",
        "remote-access",
        "tailscale",
        "websocket"
    ],
    "engines": {
        "node": ">=22"
    },
    "bin": {
        "terminal-bridge": "./bin/terminal-bridge.mjs"
    },
    "files": [
        "bin/",
        "server/dist/",
        "client/dist/",
        "client-ai/dist/",
        "shared/",
        "docs/screenshots/",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "format": "prettier --write . && eslint . --fix",
        "lint": "eslint .",
        "build": "cd client && npm run build && cd ../client-ai && npm run build && cd ../server && npm run build",
        "dev:server": "cd server && npm run dev",
        "dev:client": "cd client && npm run dev",
        "dev:client-ai": "cd client-ai && npm run dev",
        "start": "node bin/terminal-bridge.mjs",
        "postinstall": "node -e \"const fs=require('fs'),p=require('path'),d=p.join(__dirname,'node_modules','node-pty','prebuilds');if(fs.existsSync(d)){for(const s of fs.readdirSync(d)){const h=p.join(d,s,'spawn-helper');if(fs.existsSync(h))fs.chmodSync(h,0o755)}}\"",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@anthropic-ai/claude-agent-sdk": "^0.1.0",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "node-pty": "^1.0.0",
        "ws": "^8.16.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.0",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/ws": "^8.5.10",
        "eslint": "^9.39.0",
        "eslint-config-prettier": "^10.1.0",
        "eslint-plugin-prettier": "^5.5.0",
        "eslint-plugin-react-hooks": "^7.0.0",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "prettier": "^3.8.0",
        "puppeteer": "^24.37.5",
        "tsx": "^4.19.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.48.0"
    }
}
